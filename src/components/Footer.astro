---
const { current = "" } = Astro.props;
---

<footer>
  <span>
    &copy; {new Date().getFullYear()} Lucas Aarts
    <span class="separator">|</span>
    <a href="/bio" class="underline hover:font-bold">Contact</a>
  </span>
</footer>

<style>
  footer {
    color: var(--text-secondary);
    font-size: 0.9em;
    margin: 1em auto;
    max-width: 1400px;
    padding: 1em 2em;
    text-align: center;
    width: 100%;
  }

  .separator {
    margin: 0 0.8em;
    opacity: 0.6;
  }
</style>
