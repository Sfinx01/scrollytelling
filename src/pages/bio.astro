---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const title = "Lucas Aarts - Bio";
const description = "Academic background and professional contact information.";
const permalink = `${Astro?.site?.href}bio`;
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
  current="bio"
>
  <div class="container">
    <h1>Hi, I'm Lucas</h1>
    <div class="social-icons">
      <a href="mailto:lucasaarts@gmail.com" aria-label="Email">
        <Icon name="heroicons:envelope" />
      </a>
      <a href="https://www.linkedin.com/in/lucas-aarts" target="_blank" aria-label="LinkedIn">
        <Icon name="simple-icons:linkedin" />
      </a>
      <a href="https://github.com/yourusername" target="_blank" aria-label="Github">
        <Icon name="simple-icons:github" />
      </a>
    </div>
    <hr />

    <p>
      I am a graduate-level student currently completing my MSc in Climate & Sustainable Finance at Vrije Universiteit Amsterdam, having previously completed an MSc in Strategic Entrepreneurship from Rotterdam School of Management. I also hold dual Bachelor's degrees in Business Administration and Public Administration from VU Amsterdam.
    </p>
    <p>
      My academic and professional focus lies at the intersection of corporate finance, sustainable investing, and empirical analysis. I specialize in utilizing financial modeling and econometric scripting to analyze real-world transitions—specifically investigating mechanisms like green capital allocation and carbon intensity.
    </p>
    <p>
      In my technical workflow, I regularly use Python, R, and Excel, alongside financial data platforms such as LSEG Workspace and the Bloomberg Terminal.
    </p>
    <p>
      Outside of finance and data, I have spent time working as a Skipper and Guide facilitating canal cruises in Amsterdam, a role that honed my adaptability and direct communication skills.
    </p>
    <p>
      I am actively exploring opportunities for junior analyst and traineeship roles in sustainable finance and Venture Capital within the EU and the Netherlands.
    </p>
    
    <hr />
  </div>

  <style>
    .social-icons {
      display: flex;
      justify-content: left;
      align-items: center;
      gap: 1rem;
      margin: 0 0 2rem 0;
    }

    .social-icons a {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background-color: var(--color-bg-accent, #f3f4f6);
      color: #52525b;
      transition: transform 0.2s ease-in-out, background-color 0.2s ease-in-out;
    }

    .social-icons a:hover {
      transform: scale(1.1);
      background-color: var(--primary-color);
      color: white;
    }

    .social-icons svg {
      width: 24px;
      height: 24px;
      fill: currentColor;
    }

    .social-icons a[aria-label="Email"] svg {
      fill: none;
      stroke: currentColor;
    }
  </style>
</BaseLayout>
